# CBAMVault — Bridge MVP environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it contains secrets.

# Supabase project (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-side only — used for invite token lookup

# App URL (required for invite links in emails)
# localhost for development; set to your Vercel URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend email (required for invitation + submission notifications)
RESEND_API_KEY=
RESEND_FROM_EMAIL=CBAMVault <onboarding@resend.dev>

# Optional: redirect all emails to this inbox during local/pilot testing
# Only works when using Resend sandbox or a catch-all domain
RESEND_DEV_INBOX=

# ETS carbon price in EUR/tCO₂e — defaults to 65 if not set; update quarterly
CBAM_ETS_PRICE=65
